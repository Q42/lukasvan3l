# Kopieer naar .env en vul in. .env staat in .gitignore en verlaat je machine niet.

# Supabase (voor het schrijven van prijzen naar de database). Laat leeg om terug
# te vallen op het bestand-pad (output/prijzen.json). De service_role key is
# GEHEIM — nooit in git. Zie supabase/README.md.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

VARUVO_EMAIL=
VARUVO_WACHTWOORD=

AH_EMAIL=
AH_WACHTWOORD=

VHTG_EMAIL=
VHTG_WACHTWOORD=
